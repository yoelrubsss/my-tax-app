# JWT Secret Key
# Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Node Environment
NODE_ENV=development

# OpenAI API Key
# Required for AI chat functionality
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Resend Email Configuration
# Required for password reset emails
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@yourdomain.com

# Application URL
# Used for generating password reset links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Business API Configuration
# Required for WhatsApp webhook integration
# Get your token from: https://developers.facebook.com/apps
WHATSAPP_TOKEN=your_whatsapp_business_api_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# Gemini API Configuration
# Required for receipt scanning via WhatsApp
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
